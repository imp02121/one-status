---
interface UptimeDay {
  date: string;
  uptimePercent: number;
}

interface Props {
  days: UptimeDay[];
}

const { days } = Astro.props;

function getBarColor(percent: number): string {
  if (percent >= 99.5) return 'bg-indigo-500';
  if (percent >= 95) return 'bg-yellow-400';
  if (percent > 0) return 'bg-red-500';
  return 'bg-slate-200';
}

// Pad to 90 days if needed
const paddedDays = days.length >= 90
  ? days.slice(-90)
  : [
      ...Array.from({ length: 90 - days.length }, () => ({ date: '', uptimePercent: -1 })),
      ...days,
    ];
---
<div>
  <div class="flex items-stretch gap-[2px]" style="height: 32px;">
    {paddedDays.map((day) => (
      <div
        class:list={[
          'flex-1 rounded-[2px] transition-opacity hover:opacity-80',
          day.uptimePercent < 0 ? 'bg-slate-100' : getBarColor(day.uptimePercent),
        ]}
        title={day.date ? `${day.date}: ${day.uptimePercent.toFixed(2)}% uptime` : 'No data'}
      />
    ))}
  </div>
  <div class="mt-1.5 flex items-center justify-between">
    <span class="text-xs text-slate-400">90 days ago</span>
    <span class="text-xs text-slate-400">Today</span>
  </div>
</div>
