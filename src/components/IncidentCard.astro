---
interface Props {
  incident: {
    id: string;
    title: string;
    description: string;
    severity: 'minor' | 'major' | 'critical' | 'maintenance';
    status: 'investigating' | 'identified' | 'monitoring' | 'resolved';
    affectedServices: string[];
    startTime: number;
    resolvedTime?: number;
  };
}

const { incident } = Astro.props;

const severityDot = {
  minor: 'bg-yellow-400',
  major: 'bg-orange-400',
  critical: 'bg-red-500',
  maintenance: 'bg-blue-400',
} as const;

function formatTime(epoch: number): string {
  return new Date(epoch * 1000).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
    timeZoneName: 'short',
  });
}
---
<div class="py-4" id={incident.id}>
  <div class="flex items-start gap-3">
    <span class:list={['mt-1.5 h-2 w-2 shrink-0 rounded-full', severityDot[incident.severity]]} />
    <div class="flex-1 min-w-0">
      <div class="flex items-baseline justify-between gap-4">
        <a href={`/incident/${incident.id}`} class="text-sm font-semibold text-slate-900 hover:text-indigo-600 transition-colors">{incident.title}</a>
        <span class="shrink-0 text-xs text-slate-400">{formatTime(incident.startTime)}</span>
      </div>
      <p class="mt-1 text-sm leading-relaxed text-slate-600">{incident.description}</p>
      {incident.affectedServices.length > 0 && (
        <p class="mt-1.5 text-xs text-slate-400">
          {incident.affectedServices.join(' · ')}
        </p>
      )}
      {incident.resolvedTime && (
        <p class="mt-1.5 text-xs text-green-600">
          Resolved {formatTime(incident.resolvedTime)}
        </p>
      )}
    </div>
  </div>
</div>
