---
import IncidentCard from './IncidentCard.astro';

interface Incident {
  id: string;
  title: string;
  description: string;
  severity: 'minor' | 'major' | 'critical' | 'maintenance';
  status: 'investigating' | 'identified' | 'monitoring' | 'resolved';
  affectedServices: string[];
  startTime: number;
  resolvedTime?: number;
}

interface Props {
  incidents: Incident[];
  showEmpty?: boolean;
}

const { incidents, showEmpty = true } = Astro.props;

function formatDateHeader(epoch: number): string {
  return new Date(epoch * 1000).toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });
}

// Group incidents by date
const grouped = new Map<string, Incident[]>();
for (const incident of incidents) {
  const dateKey = formatDateHeader(incident.startTime);
  const existing = grouped.get(dateKey);
  if (existing) {
    existing.push(incident);
  } else {
    grouped.set(dateKey, [incident]);
  }
}
---
<div>
  {incidents.length === 0 && showEmpty ? (
    <div class="py-10 text-center">
      <p class="text-sm text-slate-400">No incidents reported in this period.</p>
    </div>
  ) : (
    <div class="divide-y divide-slate-100">
      {Array.from(grouped.entries()).map(([date, dateIncidents]) => (
        <div class="py-4 first:pt-0">
          <p class="text-xs font-medium uppercase tracking-wider text-slate-400">
            {date}
          </p>
          <div class="divide-y divide-slate-50">
            {dateIncidents.map((incident) => (
              <IncidentCard incident={incident} />
            ))}
          </div>
        </div>
      ))}
    </div>
  )}
</div>
