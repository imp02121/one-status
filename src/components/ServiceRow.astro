---
import UptimeBar from './UptimeBar.astro';

interface UptimeDay {
  date: string;
  uptimePercent: number;
}

interface Props {
  name: string;
  status: 'operational' | 'degraded' | 'down';
  latencyMs: number;
  uptimeDays: UptimeDay[];
  uptimePercent: number;
}

const { name, status, latencyMs, uptimeDays, uptimePercent } = Astro.props;

const statusLabels = {
  operational: 'Operational',
  degraded: 'Degraded',
  down: 'Down',
} as const;

const statusColors = {
  operational: 'text-green-600',
  degraded: 'text-yellow-600',
  down: 'text-red-600',
} as const;

const uptimeColor = uptimePercent >= 99.5
  ? 'text-indigo-600'
  : uptimePercent >= 95
    ? 'text-yellow-600'
    : 'text-red-600';
---
<div class="border-b border-slate-100 py-6 last:border-b-0">
  <!-- Top row: name + status -->
  <div class="mb-3 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="text-sm font-medium text-slate-900">{name}</span>
      {latencyMs > 0 && (
        <span class="text-xs font-mono text-slate-400">{latencyMs}ms</span>
      )}
    </div>
    <div class="flex items-center gap-3">
      <span class:list={['text-sm font-medium', statusColors[status]]}>
        {statusLabels[status]}
      </span>
      <span class:list={['text-sm font-semibold tabular-nums', uptimeColor]}>
        {uptimePercent.toFixed(2)}% uptime
      </span>
    </div>
  </div>

  <!-- Uptime bars -->
  <UptimeBar days={uptimeDays} />
</div>
