---
const apiBase = import.meta.env.PUBLIC_STATUS_API_URL || 'https://status-api.bundlenudge.com';
---
<div id="subscribe" class="border-t border-slate-200 pt-8">
  <div class="flex flex-col items-center text-center sm:flex-row sm:items-start sm:text-left sm:justify-between">
    <div>
      <h3 class="text-sm font-semibold text-slate-900">Get notified</h3>
      <p class="mt-0.5 text-sm text-slate-500">
        Receive email updates when services are disrupted.
      </p>
    </div>

    <form id="subscribe-form" data-api-base={apiBase} class="mt-4 flex gap-2 sm:mt-0">
      <input
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        class="w-56 rounded-lg border border-slate-200 px-3 py-2 text-sm transition-colors focus:border-slate-400 focus:outline-none"
      />
      <button
        type="submit"
        class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white transition-opacity hover:opacity-90"
      >
        Subscribe
      </button>
    </form>
  </div>

  <div id="subscribe-success" class="mt-3 hidden text-sm text-green-600">
    Subscribed. You'll receive an email when service status changes.
  </div>
  <div id="subscribe-error" class="mt-3 hidden text-sm text-red-600">
    Something went wrong. Please try again.
  </div>
</div>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement;
  const successEl = document.getElementById('subscribe-success') as HTMLDivElement;
  const errorEl = document.getElementById('subscribe-error') as HTMLDivElement;
  const apiBase = form.dataset.apiBase;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successEl.classList.add('hidden');
    errorEl.classList.add('hidden');

    const formData = new FormData(form);
    const email = formData.get('email') as string;

    try {
      const res = await fetch(`${apiBase}/api/subscribe`, {
        method: 'POST',
        body: JSON.stringify({ email }),
        headers: { 'Content-Type': 'application/json' },
      });

      if (res.ok) {
        successEl.classList.remove('hidden');
        form.reset();
      } else {
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.classList.remove('hidden');
    }
  });
</script>
