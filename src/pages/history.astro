---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import IncidentTimeline from '../components/IncidentTimeline.astro';
import { fetchIncidents } from '../lib/api';

const url = new URL(Astro.request.url);
const page = Math.max(1, Number(url.searchParams.get('page')) || 1);
const limit = 20;

const data = await fetchIncidents(page, limit);
const totalPages = Math.ceil(data.total / limit) || 1;
---
<BaseLayout
  title="Incident History - BundleNudge Status"
  description="Full incident history for BundleNudge services."
>
  <Header />

  <main class="mx-auto max-w-3xl px-6 py-10">
    <div class="flex items-baseline justify-between">
      <div>
        <h1 class="text-lg font-semibold text-slate-900">Incident History</h1>
        <p class="mt-1 text-sm text-slate-500">
          Complete log of past incidents and maintenance.
        </p>
      </div>
      <a
        href="/"
        class="text-xs font-medium text-indigo-600 transition-colors hover:text-indigo-700"
      >
        &larr; Current status
      </a>
    </div>

    <div class="mt-8">
      <IncidentTimeline incidents={data.incidents} />
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="mt-8 flex items-center justify-between border-t border-slate-100 pt-6">
        {page > 1 ? (
          <a
            href={`/history?page=${page - 1}`}
            class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm font-medium text-slate-700 transition-colors hover:border-slate-300"
          >
            Previous
          </a>
        ) : (
          <span />
        )}
        <span class="text-xs text-slate-400">
          Page {page} of {totalPages}
        </span>
        {page < totalPages ? (
          <a
            href={`/history?page=${page + 1}`}
            class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm font-medium text-slate-700 transition-colors hover:border-slate-300"
          >
            Next
          </a>
        ) : (
          <span />
        )}
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>
