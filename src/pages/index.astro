---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StatusBadge from '../components/StatusBadge.astro';
import ServiceRow from '../components/ServiceRow.astro';
import IncidentBanner from '../components/IncidentBanner.astro';
import IncidentTimeline from '../components/IncidentTimeline.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import { fetchStatus, fetchUptime, fetchIncidents } from '../lib/api';
import type { Incident } from '../lib/api';

const statusData = await fetchStatus();
const incidentsData = await fetchIncidents(1, 50);

// Enrich each service with uptime data (parallel fetches)
const enrichedServices = await Promise.all(
  statusData.services.map(async (svc) => {
    const days = await fetchUptime(svc.slug);
    const validDays = days.filter((d) => d.uptimePercent >= 0);
    const avgUptime =
      validDays.length > 0
        ? validDays.reduce((sum, d) => sum + d.uptimePercent, 0) / validDays.length
        : -1;
    return {
      ...svc,
      uptimeDays: days,
      uptimePercent: avgUptime >= 0 ? avgUptime : 100,
    };
  })
);

const activeIncidents = incidentsData.incidents.filter(
  (i: Incident) => i.status !== 'resolved'
);

const now = Math.floor(Date.now() / 1000);
const fourteenDaysAgo = now - 14 * 24 * 60 * 60;
const recentResolved = incidentsData.incidents.filter(
  (i: Incident) => i.status === 'resolved' && i.startTime >= fourteenDaysAgo
);

function relativeTime(epoch: number): string {
  const diff = Math.floor(Date.now() / 1000) - epoch;
  if (diff < 60) return 'just now';
  if (diff < 3600) return `${Math.floor(diff / 60)} min ago`;
  if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
  return new Date(epoch * 1000).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}
---
<BaseLayout
  title="BundleNudge Status"
  description="Real-time status and uptime monitoring for BundleNudge services."
>
  <Header />

  <main class="mx-auto max-w-3xl px-6 py-10">
    <!-- Active Incident Banners -->
    {activeIncidents.length > 0 && (
      <div class="mb-8 space-y-4">
        {activeIncidents.map((incident) => (
          <IncidentBanner incident={incident} />
        ))}
      </div>
    )}

    <!-- Overall Status -->
    <StatusBadge status={statusData.overall} />

    {/* Custom status message from admin dashboard */}
    {statusData.message?.text && (
      <div class="mt-4 rounded-lg border border-indigo-100 bg-indigo-50/50 px-4 py-3 text-center">
        <p class="text-sm text-indigo-900">{statusData.message.text}</p>
        {statusData.message.updatedAt && (
          <p class="mt-1 text-xs text-indigo-400">
            Updated {new Date(statusData.message.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}
          </p>
        )}
      </div>
    )}

    {statusData.lastChecked > 0 ? (
      <p class="mt-3 text-center text-xs text-slate-400">
        Last checked {relativeTime(statusData.lastChecked)} · Checks every 5 minutes
      </p>
    ) : (
      <p class="mt-3 text-center text-xs text-slate-400">
        Status data unavailable — checks run every 5 minutes
      </p>
    )}

    <!-- Services -->
    <div class="mt-10">
      {enrichedServices.length > 0 ? (
        <div class="divide-y divide-slate-100">
          {enrichedServices.map((service) => (
            <ServiceRow
              name={service.name}
              status={service.status}
              latencyMs={service.latencyMs}
              uptimeDays={service.uptimeDays}
              uptimePercent={service.uptimePercent}
            />
          ))}
        </div>
      ) : (
        <div class="py-16 text-center">
          <p class="text-sm text-slate-400">Waiting for first health check...</p>
        </div>
      )}
    </div>

    <!-- Past Incidents -->
    <div class="mt-12">
      <div class="flex items-baseline justify-between">
        <h2 class="text-sm font-semibold text-slate-900">Past Incidents</h2>
        <a
          href="/history"
          class="text-xs font-medium text-indigo-600 transition-colors hover:text-indigo-700"
        >
          View all &rarr;
        </a>
      </div>
      <div class="mt-4">
        <IncidentTimeline incidents={recentResolved} />
      </div>
    </div>

    <!-- SLA -->
    <div class="mt-12 text-center">
      <p class="text-xs text-slate-400">
        We commit to 99.9% uptime.
        <a
          href="https://bundlenudge.com/sla"
          class="font-medium text-indigo-600 transition-colors hover:text-indigo-700"
        >
          View our SLA
        </a>
      </p>
    </div>

    <!-- Subscribe -->
    <div class="mt-12">
      <SubscribeForm />
    </div>
  </main>

  <Footer />
</BaseLayout>
