---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { fetchIncident } from '../../lib/api';

const { id } = Astro.params;
const data = id ? await fetchIncident(id) : null;

if (!data) {
  return Astro.redirect('/history');
}

const { incident, updates } = data;

const severityColor = {
  minor: 'bg-yellow-100 text-yellow-800 border-yellow-200',
  major: 'bg-orange-100 text-orange-800 border-orange-200',
  critical: 'bg-red-100 text-red-800 border-red-200',
  maintenance: 'bg-blue-100 text-blue-800 border-blue-200',
} as const;

const statusColor = {
  investigating: 'text-red-600',
  identified: 'text-orange-600',
  monitoring: 'text-yellow-600',
  resolved: 'text-green-600',
} as const;

const statusDot = {
  investigating: 'bg-red-500',
  identified: 'bg-orange-500',
  monitoring: 'bg-yellow-500',
  resolved: 'bg-green-500',
} as const;

function formatTime(epoch: number): string {
  return new Date(epoch * 1000).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
    timeZoneName: 'short',
  });
}

function formatUpdateTime(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  });
}
---
<BaseLayout
  title={`${incident.title} - BundleNudge Status`}
  description={incident.description || `Incident: ${incident.title}`}
>
  <Header />

  <main class="mx-auto max-w-3xl px-6 py-10">
    <a
      href="/history"
      class="mb-6 inline-flex items-center gap-1 text-xs font-medium text-indigo-600 transition-colors hover:text-indigo-700"
    >
      &larr; All incidents
    </a>

    <!-- Incident header -->
    <div class="mt-4">
      <div class="flex items-start gap-3">
        <span class:list={[
          'mt-0.5 inline-flex rounded-full border px-2.5 py-0.5 text-xs font-semibold capitalize',
          severityColor[incident.severity],
        ]}>
          {incident.severity}
        </span>
        <span class:list={[
          'mt-0.5 text-xs font-medium capitalize',
          statusColor[incident.status],
        ]}>
          {incident.status}
        </span>
      </div>

      <h1 class="mt-3 text-xl font-semibold text-slate-900">{incident.title}</h1>

      {incident.description && (
        <p class="mt-2 text-sm leading-relaxed text-slate-600">{incident.description}</p>
      )}

      <div class="mt-3 flex flex-wrap items-center gap-4 text-xs text-slate-400">
        <span>Started {formatTime(incident.startTime)}</span>
        {incident.resolvedTime && (
          <span class="text-green-600">Resolved {formatTime(incident.resolvedTime)}</span>
        )}
      </div>

      {incident.affectedServices.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {incident.affectedServices.map((svc) => (
            <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">
              {svc}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Timeline -->
    {updates.length > 0 && (
      <div class="mt-10">
        <h2 class="text-sm font-semibold text-slate-900">Timeline</h2>
        <div class="mt-4 space-y-0">
          {updates.map((update, i) => (
            <div class="relative flex gap-4 pb-6 last:pb-0">
              {/* Vertical line */}
              {i < updates.length - 1 && (
                <div class="absolute left-[7px] top-4 h-full w-px bg-slate-200" />
              )}
              {/* Dot */}
              <div class="relative z-10 mt-1">
                <span class:list={[
                  'block h-3.5 w-3.5 rounded-full border-2 border-white',
                  statusDot[update.status as keyof typeof statusDot] || 'bg-slate-400',
                ]} />
              </div>
              {/* Content */}
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline justify-between gap-2">
                  <span class:list={[
                    'text-xs font-semibold capitalize',
                    statusColor[update.status as keyof typeof statusColor] || 'text-slate-600',
                  ]}>
                    {update.status}
                  </span>
                  <span class="shrink-0 text-xs text-slate-400">{formatUpdateTime(update.createdAt)}</span>
                </div>
                <p class="mt-1 text-sm leading-relaxed text-slate-600">{update.message}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {updates.length === 0 && (
      <div class="mt-10 rounded-lg border border-slate-100 py-8 text-center">
        <p class="text-sm text-slate-400">No updates posted yet.</p>
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>
